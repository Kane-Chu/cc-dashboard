               scriptText = "if [ -n &quot;$WORKSPACE_PATH&quot; ]; then&#10;  SERVER_JS=&quot;$(dirname &quot;$(dirname &quot;$WORKSPACE_PATH&quot;)&quot;)/../../server.js&quot;&#10;else&#10;  SERVER_JS=$(find &quot;$HOME&quot; -maxdepth 5 -name &quot;server.js&quot; -path &quot;*/cc-dashboard/*&quot; 2&gt;/dev/null | head -1)&#10;fi&#10;if [ -n &quot;$SERVER_JS&quot; ] &amp;&amp; [ -f &quot;$SERVER_JS&quot; ] &amp;&amp; ! curl -sf http://localhost:7777/api/sessions &gt;/dev/null 2&gt;&amp;1; then&#10;  node &quot;$SERVER_JS&quot; &amp;&#10;  sleep 3&#10;fi&#10;">
